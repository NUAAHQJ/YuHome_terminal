[ req ]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[ dn ]
C = CN
ST = Local
L = Local
O = My Smart Home
OU = MQTT Broker
CN = 192.168.3.5

[ v3_req ]
basicConstraints = CA:false
keyUsage = critical,digitalSignature,keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = localhost
DNS.2 = my-smart-home-broker
IP.1 = 127.0.0.1
IP.2 = 192.168.3.5
IP.3 = 192.168.3.103
